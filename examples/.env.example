# Copy this to .env and replace the placeholder values before first startup.
# This file is intentionally conservative: it is for a parallel op-reth bring-up
# that does NOT stomp on an existing geth fallback.

# Required L1 endpoints
L1_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/REPLACE_ME
L1_BEACON_URL=https://eth-mainnet-beacon.example.invalid/REPLACE_ME

# Runtime images pinned from the currently working parallel Shape attempt
OP_RETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-reth:v2.2.2
OP_NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.18.0

# Canonical host paths
RETH_DATA_DIR=/root/shape-mainnet-op-reth-data
OP_NODE_DATA_DIR=/root/shape-mainnet-op-node-reth-data
RETH_CONFIG_DIR=/root/.shape-mainnet-op-reth-config
JWT_SECRET_PATH=/root/.shape-mainnet-op-reth-config/jwt.hex

# Explicit runtime config artifacts
RETH_CONFIG_FILE=/root/.shape-mainnet-op-reth-config/reth.uploaded.toml
GENESIS_L2_FILE=/root/.shape-mainnet-op-reth-config/genesis-l2.runtime.json
ROLLUP_CONFIG_FILE=/root/.shape-mainnet-op-reth-config/rollup.runtime.json

# Isolated ports for running beside a live geth stack
RETH_HTTP_PORT=18545
RETH_WS_PORT=18546
RETH_AUTH_PORT=18551
RETH_P2P_PORT=31303
OP_NODE_RPC_PORT=19545
OP_NODE_P2P_PORT=19222
OP_NODE_METRICS_PORT=17300

# Shape L2 RPCs used by the current recipe
SHAPE_SEQUENCER_URL=https://mainnet.shape.network
SHAPE_HISTORICAL_RPC_URL=https://mainnet.shape.network

# Shape bootnodes: replace with the explicit values you actually validated.
# Keep this as a comma-separated list for docker compose.
OP_NODE_BOOTNODES=REPLACE_WITH_VALIDATED_BOOTNODES
